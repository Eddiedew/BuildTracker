# ============================================================
# BuildFlow — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Service role key — used ONLY in edge functions (server-side)
# NEVER expose this in the browser / frontend code
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Stripe ───────────────────────────────────────────────────
# Found in: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Webhook signing secret — found in Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Price IDs — found in Stripe Dashboard > Products > Prices
# Create these in Stripe and paste the price IDs here
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_BIZ_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_BIZ_ANNUAL=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Frontend (embedded in index.html) ────────────────────────
# These are safe to expose — they are the public-facing keys.
# Edit the constants directly in index.html (see SETUP.md).
# SUPABASE_URL=  (same as above)
# SUPABASE_ANON_KEY=  (same as above)
